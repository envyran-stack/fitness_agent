# Streamlit Community Cloud 배포 시, 이 내용을 앱 Settings → Secrets 에 그대로 붙여넣으세요.
# (로컬 개발에는 .env를 쓰므로, 이 파일 자체는 필요 없습니다.)

OPENAI_API_KEY = "sk-..."

SMTP_USER = "your@gmail.com"
SMTP_PASSWORD = "abcdefghijklmnop"
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
REPORT_EMAIL = "your@gmail.com"

# (선택) 지인이 PIN을 모른 채 프로필을 만들고 연락이 끊겼을 때, 프로필 삭제
# 화면에서 이 비밀번호로 PIN 없이 강제 삭제할 수 있다. 비워두면 이 기능이 숨겨진다.
ADMIN_PASSWORD = "직접 정한 비밀번호로 바꾸세요"
