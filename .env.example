# OpenAI
OPENAI_API_KEY=sk-...

# Gmail SMTP — 반드시 "앱 비밀번호" 사용 (일반 Gmail 비밀번호 X)
# 1) https://myaccount.google.com/security → 2단계 인증 ON
# 2) https://myaccount.google.com/apppasswords → 메일용 16자리 생성
# 3) 아래 SMTP_PASSWORD 에 16자리 입력 (공백 있어도 자동 제거됨)
SMTP_USER=your@gmail.com
SMTP_PASSWORD=abcdefghijklmnop
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# 리포트 수신 이메일 (미설정 시 SMTP_USER 사용)
REPORT_EMAIL=your@gmail.com

# (선택) 관리자 비밀번호 — 지인이 PIN을 모른 채 프로필을 만들어두고 연락이
# 끊겼을 때, 프로필 삭제 화면에서 이 비밀번호로 PIN 확인 없이 강제 삭제할 수 있다.
# 설정하지 않으면 이 기능(관리자 강제 삭제) 자체가 화면에 나타나지 않는다.
ADMIN_PASSWORD=
